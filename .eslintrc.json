{
  "extends": ["next/core-web-vitals", "next/typescript"],
  "rules": {
    "@typescript-eslint/no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_",
        "caughtErrorsIgnorePattern": "^_"
      }
    ]
  },
  "overrides": [
    {
      "files": ["src/__tests__/**/*.{ts,tsx}", "src/__mocks__/**/*.{ts,tsx}"],
      "rules": {
        "@next/next/no-img-element": "off"
      }
    }
  ]
}
